{
  "name": "advanced-writer-mcp",
  "version": "0.1.0",
  "description": "MCP server for neurochemically-grounded narrative engineering",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.mcp.json && cp -r src/references dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "auto-draft": "npm run build && node dist/cli/auto-draft.js",
    "dev:ui": "next dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/react": "^3.0.210",
    "@modelcontextprotocol/sdk": "latest",
    "ai": "^6.0.208",
    "cheerio": "^1.2.0",
    "chromadb": "latest",
    "dotenv": "latest",
    "express": "^5.2.1",
    "neo4j-driver": "latest",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "^5.8",
    "vitest": "latest"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
