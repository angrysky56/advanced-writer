{
  "name": "advanced-writer-mcp",
  "version": "0.1.0",
  "description": "MCP server for neurochemically-grounded narrative engineering",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/references dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "chromadb": "latest",
    "dotenv": "latest",
    "express": "^5.2.1",
    "neo4j-driver": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "^5.8",
    "vitest": "latest"
  }
}
